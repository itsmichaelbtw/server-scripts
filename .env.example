# Server connection environment variables
# Copy this file to .env and fill in your values to auto-populate server connection details
# .env file is git-ignored and safe to keep locally

# Remote server IP address
SERVER_IP=

# SSH username (default: root)
SSH_USER=root

# SSH port (default: 22)
SSH_PORT=22

# Remote directory path (use single quotes to prevent local expansion of ~)
# Examples: '~/server-scripts' or '/opt/server-scripts'
REMOTE_DIR='~/server-scripts'
